# Contact form (Resend)
RESEND_API_KEY=

# Advertising (Google AdSense) — optional
NEXT_PUBLIC_ADSENSE_CLIENT=

# Cookie consent (CookieYes) — optional
NEXT_PUBLIC_COOKIEYES_ID=

# PostHog product analytics — optional
# Use the reverse-proxy path "/phog/ingest" (rewritten in next.config.ts) so
# ad-blockers see same-origin requests instead of i.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/phog/ingest

# Sentry error tracking — required for production
# DSN is safe to expose publicly (scoped to ingest, not read)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source map upload — build-time only, never reaches client
# Generate at https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
